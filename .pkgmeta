package-as: GuildOS

# Libraries are embedded directly as .lua files in Libs/
# No externals needed — avoids path conflicts with single-file libs

ignore:
  - README.md
  - CURSEFORGE.md
  - CHANGELOG.md
  - LICENSE
  - .github
  - .gitignore
  - .gitattributes
  - .luacheckrc
  - screenshots
  - "*.md"

manual-changelog:
  filename: CHANGELOG.md
  markup-type: markdown

enable-nolib-creation: no
